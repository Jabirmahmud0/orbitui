{
  "name": "@orbitui/react",
  "version": "0.1.0",
  "description": "OrbitUI enterprise-ready React component library and design system.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./components/Breadcrumbs": {
      "import": "./dist/components/Breadcrumbs/Breadcrumbs.js",
      "require": "./dist/components/Breadcrumbs/Breadcrumbs.cjs"
    },
    "./components/Button": {
      "import": "./dist/components/Button/Button.js",
      "require": "./dist/components/Button/Button.cjs"
    },
    "./components/Checkbox": {
      "import": "./dist/components/Checkbox/Checkbox.js",
      "require": "./dist/components/Checkbox/Checkbox.cjs"
    },
    "./components/Dropdown": {
      "import": "./dist/components/Dropdown/Dropdown.js",
      "require": "./dist/components/Dropdown/Dropdown.cjs"
    },
    "./components/Input": {
      "import": "./dist/components/Input/Input.js",
      "require": "./dist/components/Input/Input.cjs"
    },
    "./components/Select": {
      "import": "./dist/components/Select/Select.js",
      "require": "./dist/components/Select/Select.cjs"
    },
    "./components/Modal": {
      "import": "./dist/components/Modal/Modal.js",
      "require": "./dist/components/Modal/Modal.cjs"
    },
    "./components/Pagination": {
      "import": "./dist/components/Pagination/Pagination.js",
      "require": "./dist/components/Pagination/Pagination.cjs"
    },
    "./components/RadioGroup": {
      "import": "./dist/components/RadioGroup/RadioGroup.js",
      "require": "./dist/components/RadioGroup/RadioGroup.cjs"
    },
    "./components/Tabs": {
      "import": "./dist/components/Tabs/Tabs.js",
      "require": "./dist/components/Tabs/Tabs.cjs"
    },
    "./components/Textarea": {
      "import": "./dist/components/Textarea/Textarea.js",
      "require": "./dist/components/Textarea/Textarea.cjs"
    },
    "./components/Tooltip": {
      "import": "./dist/components/Tooltip/Tooltip.js",
      "require": "./dist/components/Tooltip/Tooltip.cjs"
    },
    "./providers/OrbitProvider": {
      "import": "./dist/providers/OrbitProvider.js",
      "require": "./dist/providers/OrbitProvider.cjs"
    },
    "./hooks/useControllableState": {
      "import": "./dist/hooks/useControllableState.js",
      "require": "./dist/hooks/useControllableState.cjs"
    },
    "./hooks/useId": {
      "import": "./dist/hooks/useId.js",
      "require": "./dist/hooks/useId.cjs"
    },
    "./hooks/useMediaQuery": {
      "import": "./dist/hooks/useMediaQuery.js",
      "require": "./dist/hooks/useMediaQuery.cjs"
    },
    "./utils/cn": {
      "import": "./dist/utils/cn.js",
      "require": "./dist/utils/cn.cjs"
    },
    "./utils/composeRefs": {
      "import": "./dist/utils/composeRefs.js",
      "require": "./dist/utils/composeRefs.cjs"
    },
    "./utils/createContext": {
      "import": "./dist/utils/createContext.js",
      "require": "./dist/utils/createContext.cjs"
    },
    "./utils/polymorphic": {
      "import": "./dist/utils/polymorphic.js",
      "require": "./dist/utils/polymorphic.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "node scripts/prepare-husky.mjs",
    "lint": "eslint . --ext js,jsx",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "tokens:build": "style-dictionary build --config style-dictionary/config.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "check:bundle": "node scripts/check-bundle-size.js",
    "release": "semantic-release"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "orbitui",
    "react",
    "design-system",
    "component-library",
    "vite"
  ],
  "author": "Jabir Mahmud",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-core": "^4.11.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.4",
    "style-dictionary": "^5.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react-aria": "^3.47.0",
    "tailwind-merge": "^3.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jabirmahmud0/orbitui.git"
  },
  "homepage": "https://github.com/Jabirmahmud0/orbitui#readme",
  "bugs": {
    "url": "https://github.com/Jabirmahmud0/orbitui/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}

